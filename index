        nav a { color: #0b3b66; text-decoration: none; margin: 0 20px; font-weight: bold; font-size: 1rem; }
        nav a:hover { color: #000; text-decoration: underline; }
        .container { padding: 30px 20px; max-width: 1000px; margin: auto; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.05); margin-top: 25px; border-radius: 8px; }
