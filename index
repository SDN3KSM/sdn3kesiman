        @media(min-width: 768px) { .grid-info { grid-template-columns: 1fr 1fr; } }
        .card { background: #fdfdfd; padding: 20px; border-left: 5px solid #0b3b66; box-shadow: 0 2px 5px rgba(0,0,0,0.05); border-radius: 4px; }
        footer { text-align: center; padding: 25px; background-color: #0b3b66; color: white; margin-top: 50px; font-size: 0.9rem; }
